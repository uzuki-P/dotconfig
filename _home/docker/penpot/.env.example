# Keep this pinned and update in small increments.
PENPOT_VERSION=2.16
PENPOT_PUBLIC_URI=https://penpot.ts.example.com

# Generate with: python3 -c 'import secrets; print(secrets.token_urlsafe(64))'
PENPOT_SECRET_KEY=replace-with-a-random-secret

# Local Mailpit SMTP catcher in ../mailpit.
PENPOT_SMTP_HOST=mailpit
PENPOT_SMTP_PORT=1025
PENPOT_SMTP_TLS=false
PENPOT_SMTP_DEFAULT_FROM=Penpot <penpot@localhost>
PENPOT_SMTP_DEFAULT_REPLY_TO=Penpot <penpot@localhost>

# Cloudflare API token for DNS-01 certificate validation
# Get it at: https://dash.cloudflare.com/profile/api-tokens
# Use the "Edit zone DNS" template, scoped to your zone
CLOUDFLARE_API_TOKEN=

# Tailnet node IP that Caddy should bind to and proxy ttyd through.
# Use your own Tailscale IP; the default is loopback so the config
# still validates on a fresh checkout.
CADDY_TS_IP=127.0.0.1

# Base domain under the tailnet wildcard certificate.
# Cloudflare must have a DNS-only wildcard A record for
# *.<CADDY_TS_BASE_DOMAIN> pointing at CADDY_TS_IP.
CADDY_TS_BASE_DOMAIN=ts.example.com

#!/usr/bin/env bash
# Foreground ttyd process supervised by ~/.config/systemd/user/ttyd.service.

set -euo pipefail

PORT="${TTYD_PORT:-7681}"
INTERFACE="${TTYD_INTERFACE:-tailscale0}"
MAX_CLIENTS="${TTYD_MAX_CLIENTS:-1}"
FONT_FAMILY="${TTYD_FONT_FAMILY:-Maple Mono NF CN}"
FONT_SIZE="${TTYD_FONT_SIZE:-16}"

command -v ttyd >/dev/null || {
  echo "ttyd not found in PATH." >&2
  exit 1
}

if ! ip link show "$INTERFACE" >/dev/null 2>&1; then
  echo "Network interface '$INTERFACE' is not available." >&2
  exit 1
fi

# Serve a normal login shell. Run `herdr` from the browser after connecting.
# No credentials are configured here: access is restricted by the Tailscale
# interface and the tailnet ACLs/grants.
exec ttyd \
  -p "$PORT" \
  -i "$INTERFACE" \
  -O \
  -W \
  -m "$MAX_CLIENTS" \
  -t "fontFamily=$FONT_FAMILY" \
  -t "fontSize=$FONT_SIZE" \
  -s 1 \
  -- fish -l
